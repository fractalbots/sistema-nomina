@model SistemaNomina.Models.Title
@{
    ViewData["Title"] = "Eliminar Título";
}

<div class="container mt-4">
    <h2>¿Eliminar este título?</h2>
    <p><strong>Empleado:</strong> @Model.Employee?.first_name @Model.Employee?.last_name</p>
    <p><strong>Título:</strong> @Model.title</p>
    <p><strong>Período:</strong> @Model.from_date - @(Model.to_date ?? "Activo")</p>
    <form method="post">
        <button type="submit" class="btn btn-danger">Sí, eliminar</button>
        <a href="/Titles" class="btn btn-secondary">Cancelar</a>
    </form>
</div>