@model SistemaNomina.Models.Department
@{
    ViewData["Title"] = "Editar Departamento";
}

<div class="container mt-4">
    <h2>Editar Departamento</h2>
    <form method="post">
        <input asp-for="dept_no" type="hidden" />
        <div class="mb-3">
            <label>Código</label>
            <input asp-for="dept_no" class="form-control" readonly />
        </div>
        <div class="mb-3">
            <label>Nombre</label>
            <input asp-for="dept_name" class="form-control" />
            <span asp-validation-for="dept_name" class="text-danger"></span>
        </div>
        <button type="submit" class="btn btn-warning">Actualizar</button>
        <a href="/Departments" class="btn btn-secondary">Cancelar</a>
    </form>
</div>