@model SistemaNomina.Models.Department
@{
    ViewData["Title"] = "Nuevo Departamento";
}

<div class="container mt-4">
    <h2>Nuevo Departamento</h2>
    <form method="post">
        <div class="mb-3">
            <label>Código (dept_no)</label>
            <input asp-for="dept_no" class="form-control" />
            <span asp-validation-for="dept_no" class="text-danger"></span>
        </div>
        <div class="mb-3">
            <label>Nombre</label>
            <input asp-for="dept_name" class="form-control" />
            <span asp-validation-for="dept_name" class="text-danger"></span>
        </div>
        <button type="submit" class="btn btn-primary">Guardar</button>
        <a href="/Departments" class="btn btn-secondary">Cancelar</a>
    </form>
</div>