@model SistemaNomina.Models.DeptManager
@{
    ViewData["Title"] = "Nuevo Gerente";
}

<div class="container mt-4">
    <h2>Asignar Gerente de Departamento</h2>
    @if (!ViewData.ModelState.IsValid)
    {
        <div class="alert alert-danger">
            @foreach (var e in ViewData.ModelState.Values.SelectMany(v => v.Errors))
            {
                <p>@e.ErrorMessage</p>
            }
        </div>
    }
    <form method="post">
        <div class="mb-3">
            <label>Empleado (Gerente)</label>
            <select asp-for="emp_no" class="form-control">
                @foreach (var e in ViewBag.Employees as List<SistemaNomina.Models.Employee>)
                {
                    <option value="@e.emp_no">@e.first_name @e.last_name</option>
                }
            </select>
        </div>
        <div class="mb-3">
            <label>Departamento</label>
            <select asp-for="dept_no" class="form-control">
                @foreach (var d in ViewBag.Departments as List<SistemaNomina.Models.Department>)
                {
                    <option value="@d.dept_no">@d.dept_name</option>
                }
            </select>
        </div>
        <div class="mb-3">
            <label>Desde</label>
            <input asp-for="from_date" type="date" class="form-control" />
        </div>
        <div class="mb-3">
            <label>Hasta (dejar vacío si está activo)</label>
            <input asp-for="to_date" type="date" class="form-control" />
        </div>
        <button type="submit" class="btn btn-primary">Guardar</button>
        <a href="/DeptManager" class="btn btn-secondary">Cancelar</a>
    </form>
</div>
